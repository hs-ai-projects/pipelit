{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feishu-dev/l3-report",
  "description": "L3 分析报告输出契约 — L3 任务 Phase 1.3 输出报告时必须包含的字段",
  "type": "object",
  "required": ["task_title", "task_link", "root_cause_hypothesis", "affected_scope", "split_suggestions"],
  "properties": {
    "task_title": {
      "type": "string",
      "description": "飞书任务标题"
    },
    "task_link": {
      "type": "string",
      "pattern": "^https://",
      "description": "飞书任务链接"
    },
    "root_cause_hypothesis": {
      "type": "string",
      "minLength": 10,
      "description": "根据任务描述和代码库推断的可能根因（一到多段）"
    },
    "affected_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "可能相关的模块/文件列表"
    },
    "log_summary": {
      "type": ["string", "null"],
      "description": "观测云 / log-provider 日志摘要，null 表示无日志数据"
    },
    "log_conclusion": {
      "type": ["string", "null"],
      "description": "日志数据对根因假设的印证或修正，log_summary 为 null 时此字段也为 null"
    },
    "split_suggestions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "description"],
        "properties": {
          "index": { "type": "integer", "minimum": 1 },
          "description": { "type": "string", "description": "子任务描述" }
        }
      },
      "description": "建议拆分的子任务列表"
    }
  }
}
